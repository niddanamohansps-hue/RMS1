# ─── Security Settings ────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production-use-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=sps-rms-swxo.onrender.com

# ─── Database Settings ────────────────────────────────────────────────────────
# Option A: Connect to local database (default)
DB_NAME=rms_db
DB_USER=rms_user
DB_PASSWORD=rms@123
DB_HOST=localhost
DB_PORT=5432

# Option B: Use a single connection URL (Uncomment below to test Neon/Supabase database locally)
DATABASE_URL=postgresql://neondb_owner:npg_oKua0FHhA2Dg@ep-rapid-voice-aod78ivs-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# ─── CORS & CSRF ──────────────────────────────────────────────────────────────
# Comma-separated domains allowed to connect to this API
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Authentication Settings ─────────────────────────────────────────────────
# JWT Token lifetimes (in minutes)
ACCESS_TOKEN_LIFETIME=120
REFRESH_TOKEN_LIFETIME=1440

# ─── Background Tasks & Caching ──────────────────────────────────────────────
# Set to True to enable Redis cache and Celery workers (requires paid tiers)
# Set to False to run completely free (threads for tasks, local memory for cache)
USE_REDIS_CELERY=False

# If USE_REDIS_CELERY is True, configure URLs below:
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
